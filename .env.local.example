# Dealer app — copy to .env.local and fill in. Used by: npm run dev:dealer, db:migrate, db:seed.
# Get these from Supabase: Project Settings → API, and Database → Connection string.

DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# Optional: direct connection (port 5432) for db:migrate, db:migrate:status, db:reset — avoids pooler hang
# DIRECT_DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000
COOKIE_ENCRYPTION_KEY=
CRON_SECRET=

# When platform calls dealer internal API (same value as in .env.platform-admin):
# INTERNAL_API_JWT_SECRET=

# Demo pipeline and demo login (optional). Create demo user: npm run demo:create-login --prefix apps/dealer
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_PASSWORD=DemoPassword123!
