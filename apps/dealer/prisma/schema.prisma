// DMS Core Platform — Prisma schema
// See docs/design/core-platform-spec.md §1
// Partial uniques (active membership, role name) enforced in migration + app layer.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DealershipLifecycleStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum InboxChannel {
  SMS
  EMAIL
  WHATSAPP
  FACEBOOK_MESSENGER
  INSTAGRAM_DM
  WEB_CHAT
  MARKETPLACE_LEAD
  SYSTEM
}

enum InboxConversationStatus {
  OPEN
  SNOOZED
  CLOSED
  ARCHIVED
  SPAM
}

enum InboxRoutingStatus {
  UNASSIGNED
  ASSIGNED
  ESCALATED
}

enum InboxWaitingOn {
  NONE
  CUSTOMER
  TEAM
}

enum InboxMessageDirection {
  INBOUND
  OUTBOUND
}

enum InboxMessageType {
  TEXT
  MEDIA
  SYSTEM
  LEAD
  STATUS_UPDATE
}

enum InboxParticipantRole {
  CUSTOMER
  REP
  SYSTEM
  EXTERNAL_PARTICIPANT
}

enum InboxMessageEventType {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  BOUNCED
  OPENED
  CLICKED
  REPLIED
}

enum InboxChannelAccountStatus {
  ACTIVE
  PAUSED
  DISCONNECTED
}

model Dealership {
  id                  String                    @id @default(uuid()) @db.Uuid
  name                String
  slug                String?                   @unique
  settings            Json?
  isActive            Boolean                   @default(true) @map("is_active")
  platformDealershipId String?                   @unique @map("platform_dealership_id") @db.Uuid
  lifecycleStatus     DealershipLifecycleStatus @default(ACTIVE) @map("lifecycle_status")
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  locations        DealershipLocation[]
  provisioningIdempotencies ProvisioningIdempotency[]
  ownerInviteIdempotencies  OwnerInviteIdempotency[]
  roles            Role[]
  memberships      Membership[]
  dealershipInvites DealershipInvite[]
  dealerApplications DealerApplication[]
  auditLogs        AuditLog[]
  fileObjects               FileObject[]
  vehiclePhotos              VehiclePhoto[]
  inventoryAlertDismissals   InventoryAlertDismissal[]
  vehicles                   Vehicle[]
  customers                  Customer[]
  customerPhones   CustomerPhone[]
  customerEmails   CustomerEmail[]
  customerNotes   CustomerNote[]
  customerTasks   CustomerTask[]
  customerActivities CustomerActivity[]
  customerCallbacks CustomerCallback[]
  inboxConversations InboxConversation[]
  inboxParticipants InboxParticipant[]
  inboxMessages InboxMessage[]
  inboxMessageAttachments InboxMessageAttachment[]
  inboxMessageEvents InboxMessageEvent[]
  inboxChannelAccounts InboxChannelAccount[]
  deals       Deal[]
  dealFees    DealFee[]
  dealTrades  DealTrade[]
  dealHistories DealHistory[]
  dealFundings DealFunding[]
  dealTitles   DealTitle[]
  dealDmvChecklistItems DealDmvChecklistItem[]
  dealFinances DealFinance[]
  dealFinanceProducts DealFinanceProduct[]
  lenders               Lender[]
  financeApplications   FinanceApplication[]
  financeApplicants      FinanceApplicant[]
  financeSubmissions     FinanceSubmission[]
  financeStipulations    FinanceStipulation[]
  pipelines              Pipeline[]
  stages                 Stage[]
  opportunities          Opportunity[]
  automationRules        AutomationRule[]
  automationRuns         AutomationRun[]
  jobs                   Job[]
  sequenceTemplates      SequenceTemplate[]
  sequenceSteps          SequenceStep[]
  sequenceInstances      SequenceInstance[]
  sequenceStepInstances  SequenceStepInstance[]
  opportunityActivities  OpportunityActivity[]
  dealerJobRuns          DealerJobRun[]
  dealerJobRunsDaily     DealerJobRunsDaily[]
  savedFilters           SavedFilter[]
  savedSearches          SavedSearch[]
  bulkImportJobs         BulkImportJob[]
  vehicleVinDecodes      VehicleVinDecode[]
  vehicleValuations      VehicleValuation[]
  vehicleRecons          VehicleRecon[]
  vehicleReconLineItems  VehicleReconLineItem[]
  vehicleFloorplans      VehicleFloorplan[]
  vehicleFloorplanCurtailments VehicleFloorplanCurtailment[]
  vinDecodeCaches        VinDecodeCache[]
  vehicleBookValues      VehicleBookValue[]
  vehicleAppraisals      VehicleAppraisal[]
  inventorySourceLeads   InventorySourceLead[]
  auctionListingCaches  AuctionListingCache[]
  auctionPurchases     AuctionPurchase[]
  vehicleMarketValuations VehicleMarketValuation[]
  pricingRules          PricingRule[]
  vehicleListings        VehicleListing[]
  reconItems             ReconItem[]
  floorplanLoans         FloorplanLoan[]
  dashboardLayoutPreferences DashboardLayoutPreference[]
  inventorySummarySnapshots  InventorySummarySnapshot[]
  userDealershipPreferences  UserDealershipPreference[]
  userActiveDealerships      UserActiveDealership[]
  creditApplications        CreditApplication[]
  lenderApplications         LenderApplication[]
  lenderStipulations         LenderStipulation[]
  dealDocuments              DealDocument[]
  complianceFormInstances    ComplianceFormInstance[]
  accountingAccounts         AccountingAccount[]
  accountingTransactions     AccountingTransaction[]
  accountingEntries          AccountingEntry[]
  dealershipExpenses         DealershipExpense[]
  taxProfiles                TaxProfile[]
  intelligenceSignals        IntelligenceSignal[]
  vehicleCostEntries         VehicleCostEntry[]
  vehicleCostDocuments       VehicleCostDocument[]
  customerLastActivitySummaries CustomerLastActivitySummary[]
  vendors                    Vendor[]
  onboardingState            DealershipOnboardingState?
}

model DealershipOnboardingState {
  id                    String    @id @default(uuid()) @db.Uuid
  dealershipId          String    @unique @map("dealership_id") @db.Uuid
  currentStep           Int       @default(1) @map("current_step")
  completedSteps        Json      @default("[]") @map("completed_steps")
  skippedSteps          Json      @default("[]") @map("skipped_steps")
  inventoryPathChosen   String?   @map("inventory_path_chosen") @db.VarChar(32)
  isComplete            Boolean   @default(false) @map("is_complete")
  completedAt           DateTime? @map("completed_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  dealership Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)

  @@index([dealershipId])
  @@index([isComplete])
}

model DealershipLocation {
  id           String   @id @default(uuid()) @db.Uuid
  dealershipId String   @map("dealership_id") @db.Uuid
  name         String
  addressLine1 String?  @map("address_line1")
  addressLine2 String?  @map("address_line2")
  city         String?
  region       String?
  postalCode   String?  @map("postal_code")
  country      String?
  isPrimary    Boolean  @default(false) @map("is_primary")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  dealership Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  vehicles   Vehicle[]

  @@index([dealershipId])
  @@unique([dealershipId, name])
}

model Profile {
  id        String   @id @db.Uuid
  email     String   @unique
  fullName  String?  @map("full_name")
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  membershipsAsUser     Membership[]      @relation("Member")
  membershipsInvitedBy  Membership[]      @relation("InvitedBy")
  membershipsDisabledBy Membership[]     @relation("DisabledBy")
  activeDealership     UserActiveDealership?
  rolesDeletedBy       Role[]            @relation("RoleDeletedBy")
  invitesCreatedBy     DealershipInvite[] @relation("InviteCreatedBy")
  invitesAcceptedBy    DealershipInvite[] @relation("InviteAcceptedBy")
  auditLogs             AuditLog[]
  fileObjectsUploaded  FileObject[] @relation("UploadedBy")
  fileObjectsDeletedBy FileObject[] @relation("FileObjectDeletedBy")
  vehiclesDeletedBy    Vehicle[]   @relation("VehicleDeletedBy")
  customersAssignedTo   Customer[]  @relation("CustomerAssignedTo")
  customersBdcRep       Customer[]  @relation("CustomerBdcRep")
  customersDeletedBy   Customer[]  @relation("CustomerDeletedBy")
  customerNotesCreatedBy CustomerNote[]
  customerNotesDeletedBy CustomerNote[]   @relation("NoteDeletedBy")
  customerTasksCreatedBy  CustomerTask[]  @relation("TaskCreatedBy")
  customerTasksCompletedBy CustomerTask[] @relation("TaskCompletedBy")
  customerTasksDeletedBy   CustomerTask[] @relation("TaskDeletedBy")
  customerActivities  CustomerActivity[]
  assignedInboxConversations InboxConversation[] @relation("InboxConversationAssignedTo")
  inboxParticipants           InboxParticipant[]
  dealsDeletedBy      Deal[]           @relation("DealDeletedBy")
  dealHistoriesChangedBy DealHistory[]  @relation("DealHistoryChangedBy")
  dealFinancesDeletedBy DealFinance[]   @relation("DealFinanceDeletedBy")
  financeApplicationsCreatedBy FinanceApplication[] @relation("FinanceApplicationCreatedBy")
  opportunitiesOwned           Opportunity[]       @relation("OpportunityOwner")
  opportunityActivitiesActor  OpportunityActivity[] @relation("OpportunityActivityActor")
  pendingApproval             PendingApproval?
  userRoles                   UserRole[]
  userPermissionOverrides     UserPermissionOverride[]
  userPermissionOverridesCreatedBy UserPermissionOverride[] @relation("OverrideCreatedBy")
  savedFiltersOwned            SavedFilter[]  @relation("SavedFilterOwner")
  savedSearchesOwned           SavedSearch[]  @relation("SavedSearchOwner")
  bulkImportJobsCreatedBy      BulkImportJob[] @relation("BulkImportJobCreatedBy")
  inventoryAlertDismissals     InventoryAlertDismissal[] @relation("InventoryAlertDismissalUser")
  inventorySummarySnapshots    InventorySummarySnapshot[]
  vehicleAppraisalsAppraisedBy VehicleAppraisal[] @relation("VehicleAppraisalAppraisedBy")
  callbacksAssignedTo          CustomerCallback[] @relation("CallbackAssignedTo")
  dashboardLayoutPreferences  DashboardLayoutPreference[]
  userDealershipPreferences  UserDealershipPreference[]
  vehicleCostEntriesCreatedBy   VehicleCostEntry[]   @relation("VehicleCostEntryCreatedBy")
  vehicleCostEntriesDeletedBy   VehicleCostEntry[]   @relation("VehicleCostEntryDeletedBy")
  vehicleCostDocumentsCreatedBy VehicleCostDocument[] @relation("VehicleCostDocumentCreatedBy")
}

enum DealershipInviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

model DealershipInvite {
  id           String                @id @default(uuid()) @db.Uuid
  dealershipId String                @map("dealership_id") @db.Uuid
  email        String
  roleId       String                @map("role_id") @db.Uuid
  status       DealershipInviteStatus @default(PENDING)
  expiresAt    DateTime?              @map("expires_at")
  createdBy    String?                @map("created_by") @db.Uuid
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  acceptedAt        DateTime?             @map("accepted_at")
  acceptedByUserId  String?               @map("accepted_by_user_id") @db.Uuid
  token             String?              @unique
  dealerApplicationId String?            @map("dealer_application_id") @db.Uuid

  dealership         Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  role                Role       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  createdByProfile    Profile?   @relation("InviteCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  acceptedByProfile   Profile?   @relation("InviteAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  dealerApplication   DealerApplication? @relation("ActivationInvites", fields: [dealerApplicationId], references: [id], onDelete: SetNull)
  applicationsStarted DealerApplication[] @relation("StartedByInvite")
  memberships         Membership[]

  @@index([dealershipId])
  @@index([email])
  @@index([dealershipId, email])
  @@index([token])
  @@index([expiresAt])
  @@index([acceptedByUserId])
  @@index([dealerApplicationId])
}

model PendingApproval {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  email     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

enum DealerApplicationSource {
  invite
  public_apply
}

enum DealerApplicationStatus {
  draft
  invited
  submitted
  under_review
  approved
  rejected
  activation_sent
  activated
}

model DealerApplication {
  id                    String                   @id @default(uuid()) @db.Uuid
  source                DealerApplicationSource
  status                DealerApplicationStatus   @default(draft)
  invitedByUserId       String?                   @map("invited_by_user_id") @db.Uuid
  inviteId             String?                   @map("invite_id") @db.Uuid
  ownerEmail           String                    @map("owner_email")
  dealershipId         String?                   @map("dealership_id") @db.Uuid
  platformApplicationId String?                   @map("platform_application_id") @db.Uuid
  platformDealershipId  String?                   @map("platform_dealership_id") @db.Uuid
  submittedAt          DateTime?                 @map("submitted_at")
  approvedAt           DateTime?                 @map("approved_at")
  rejectedAt           DateTime?                 @map("rejected_at")
  activationSentAt     DateTime?                 @map("activation_sent_at")
  activatedAt          DateTime?                 @map("activated_at")
  reviewerUserId       String?                   @map("reviewer_user_id") @db.Uuid
  reviewNotes          String?                   @map("review_notes") @db.Text
  rejectionReason      String?                   @map("rejection_reason") @db.Text
  createdAt            DateTime                  @default(now()) @map("created_at")
  updatedAt            DateTime                  @updatedAt @map("updated_at")

  startedByInvite DealershipInvite?  @relation("StartedByInvite", fields: [inviteId], references: [id], onDelete: SetNull)
  dealership      Dealership?       @relation(fields: [dealershipId], references: [id], onDelete: SetNull)
  profile         DealerApplicationProfile?
  activationInvites DealershipInvite[] @relation("ActivationInvites")

  @@index([status])
  @@index([ownerEmail])
  @@index([submittedAt])
  @@index([source, status])
  @@index([dealershipId])
  @@index([inviteId])
}

model DealerApplicationProfile {
  id                    String   @id @default(uuid()) @db.Uuid
  applicationId         String   @unique @map("application_id") @db.Uuid
  businessInfo         Json?    @map("business_info")
  ownerInfo            Json?    @map("owner_info")
  primaryContact       Json?    @map("primary_contact")
  additionalLocations   Json?    @map("additional_locations")
  pricingPackageInterest Json?   @map("pricing_package_interest")
  acknowledgments      Json?    @map("acknowledgments")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  application DealerApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  description String?
  module      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions        RolePermission[]
  userPermissionOverrides UserPermissionOverride[]
  @@index([module])
}

model Role {
  id           String    @id @default(uuid()) @db.Uuid
  dealershipId String    @map("dealership_id") @db.Uuid
  key          String?   @db.VarChar(64)
  name         String
  isSystem     Boolean   @default(false) @map("is_system")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime? @map("deleted_at")
  deletedBy    String?   @map("deleted_by") @db.Uuid

  dealership         Dealership        @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  deletedByProfile   Profile?         @relation("RoleDeletedBy", fields: [deletedBy], references: [id])
  rolePermissions   RolePermission[]
  userRoles         UserRole[]
  memberships        Membership[]
  dealershipInvites  DealershipInvite[]

  @@index([dealershipId])
  @@unique([dealershipId, key])
}

model RolePermission {
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model Membership {
  id           String    @id @default(uuid()) @db.Uuid
  dealershipId String    @map("dealership_id") @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  roleId       String    @map("role_id") @db.Uuid
  invitedBy    String?   @map("invited_by") @db.Uuid
  invitedAt    DateTime? @map("invited_at")
  joinedAt     DateTime? @map("joined_at")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  disabledAt   DateTime? @map("disabled_at")
  disabledBy   String?   @map("disabled_by") @db.Uuid
  inviteId     String?   @map("invite_id") @db.Uuid

  dealership   Dealership        @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  user         Profile          @relation("Member", fields: [userId], references: [id], onDelete: Cascade)
  role         Role             @relation(fields: [roleId], references: [id], onDelete: Restrict)
  invitedByProfile Profile?     @relation("InvitedBy", fields: [invitedBy], references: [id])
  disabledByProfile Profile?    @relation("DisabledBy", fields: [disabledBy], references: [id])
  invite       DealershipInvite? @relation(fields: [inviteId], references: [id], onDelete: SetNull)

  @@index([dealershipId])
  @@index([userId])
  @@index([userId, dealershipId])
  @@index([inviteId])
}

model UserActiveDealership {
  userId             String   @id @map("user_id") @db.Uuid
  activeDealershipId String   @map("active_dealership_id") @db.Uuid
  updatedAt          DateTime @updatedAt @map("updated_at")

  user       Profile    @relation(fields: [userId], references: [id], onDelete: Cascade)
  dealership Dealership @relation(fields: [activeDealershipId], references: [id], onDelete: Cascade)

  @@index([activeDealershipId])
}

model UserRole {
  userId   String   @map("user_id") @db.Uuid
  roleId   String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model UserPermissionOverride {
  userId          String   @map("user_id") @db.Uuid
  permissionId    String   @map("permission_id") @db.Uuid
  enabled         Boolean
  createdByUserId String   @map("created_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")

  user        Profile    @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission  Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdBy   Profile    @relation("OverrideCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@id([userId, permissionId])
  @@index([permissionId])
}

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  dealershipId String?  @map("dealership_id") @db.Uuid
  actorId      String?  @map("actor_id") @db.Uuid
  action       String
  entity       String
  entityId     String?  @map("entity_id") @db.Uuid
  metadata     Json?
  ip           String?
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now())

  dealership Dealership? @relation(fields: [dealershipId], references: [id], onDelete: SetNull)
  actor      Profile?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([dealershipId])
  @@index([dealershipId, createdAt])
  @@index([dealershipId, entity, entityId])
  @@index([actorId])
}

model DashboardLayoutPreference {
  id           String   @id @default(uuid()) @db.Uuid
  dealershipId String   @map("dealership_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  layoutJson   Json     @map("layout_json")
  checksum     String?  @map("checksum") @db.VarChar(64)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  dealership Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  user       Profile    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([dealershipId, userId])
  @@index([dealershipId])
  @@index([userId])
}

enum InventorySummaryScope {
  OVERVIEW
  INTELLIGENCE
}

model InventorySummarySnapshot {
  id           String                @id @default(uuid()) @db.Uuid
  dealershipId String                @map("dealership_id") @db.Uuid
  scope        InventorySummaryScope
  userId       String                @map("user_id") @db.Uuid
  hasPipeline  Boolean               @default(false) @map("has_pipeline")
  snapshotJson Json                  @map("snapshot_json")
  computedAt   DateTime              @default(now()) @map("computed_at")
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")

  dealership Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  user       Profile    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([dealershipId, scope, userId, hasPipeline])
  @@index([dealershipId, scope, updatedAt])
}

model UserDealershipPreference {
  id           String   @id @default(uuid()) @db.Uuid
  dealershipId String   @map("dealership_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  key          String   @db.VarChar(128)
  value        String   @db.VarChar(512)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  dealership Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  user       Profile    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([dealershipId, userId, key])
  @@index([dealershipId])
  @@index([userId])
  @@map("user_dealership_preference")
}

model ProvisioningIdempotency {
  idempotencyKey       String   @id @map("idempotency_key") @db.VarChar(255)
  platformDealershipId String   @map("platform_dealership_id") @db.Uuid
  dealerDealershipId   String   @map("dealer_dealership_id") @db.Uuid
  provisionedAt        DateTime @map("provisioned_at")
  createdAt            DateTime @default(now()) @map("created_at")

  dealership Dealership @relation(fields: [dealerDealershipId], references: [id], onDelete: Cascade)

  @@index([platformDealershipId])
}

model InternalApiJti {
  jti       String   @id @db.VarChar(255)
  expiresAt DateTime @map("expires_at")

  @@index([expiresAt])
}

model DealerRateLimitEvent {
  id        String   @id @default(uuid()) @db.Uuid
  routeKey  String   @map("route_key") @db.VarChar(500)
  allowed   Boolean
  ipHash    String?  @map("ip_hash") @db.VarChar(64)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("dealer_rate_limit_events")
  @@index([routeKey, createdAt])
}

model DealerRateLimitStatsDaily {
  id                  String   @id @default(uuid()) @db.Uuid
  day                 DateTime @db.Date
  routeKey            String   @map("route_key") @db.VarChar(500)
  allowedCount        Int      @map("allowed_count")
  blockedCount        Int      @map("blocked_count")
  uniqueIpCountApprox Int?     @map("unique_ip_count_approx")
  createdAt           DateTime @default(now()) @map("created_at")

  @@unique([day, routeKey])
  @@index([day])
  @@index([routeKey])
  @@index([day, routeKey])
  @@map("dealer_rate_limit_stats_daily")
}

model OwnerInviteIdempotency {
  idempotencyKey     String   @id @map("idempotency_key") @db.VarChar(255)
  dealerDealershipId  String   @map("dealer_dealership_id") @db.Uuid
  inviteId            String   @map("invite_id") @db.Uuid
  createdAt           DateTime @default(now()) @map("created_at")

  dealership Dealership @relation(fields: [dealerDealershipId], references: [id], onDelete: Cascade)

  @@index([dealerDealershipId])
}

// Documents module: docType, title, tags (nullable so inventory-photos rows unchanged)
enum DocumentType {
  BUYERS_ORDER
  CONTRACT
  TITLE
  ODOMETER
  STIP_INCOME
  STIP_RESIDENCE
  STIP_INSURANCE
  PAYOFF
  OTHER
}

enum VendorType {
  auction
  transporter
  repair
  parts
  detail
  inspection
  title_doc
  other
}

model Vendor {
  id           String     @id @default(uuid()) @db.Uuid
  dealershipId String     @map("dealership_id") @db.Uuid
  name         String     @db.VarChar(256)
  type         VendorType
  contactName  String?    @map("contact_name") @db.VarChar(256)
  phone        String?    @db.VarChar(64)
  email        String?    @db.VarChar(256)
  address      String?    @db.VarChar(512)
