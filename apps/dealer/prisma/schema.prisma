  maxAmountCents          BigInt?                @map("max_amount_cents")
  maxAdvanceBps           Int?                   @map("max_advance_bps")
  termMonths              Int?                   @map("term_months")
  downPaymentRequiredCents BigInt?               @map("down_payment_required_cents")
  decisionSummary         String?                @map("decision_summary") @db.Text
  rawDecisionJson         Json?                  @map("raw_decision_json")
  submittedAt             DateTime?             @map("submitted_at")
  decisionedAt            DateTime?             @map("decisioned_at")
  createdByUserId         String?               @map("created_by_user_id") @db.Uuid
  updatedByUserId         String?               @map("updated_by_user_id") @db.Uuid
  createdAt               DateTime              @default(now()) @map("created_at")
  updatedAt               DateTime              @updatedAt @map("updated_at")

  dealership   Dealership       @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  creditApplication CreditApplication @relation(fields: [creditApplicationId], references: [id], onDelete: Cascade)
  deal         Deal             @relation(fields: [dealId], references: [id], onDelete: Cascade)
  stipulations LenderStipulation[]
  dealFundings DealFunding[]

  @@index([dealershipId])
  @@index([dealershipId, creditApplicationId])
  @@index([dealershipId, dealId])
  @@index([dealershipId, status])
  @@index([dealershipId, createdAt])
}

model LenderStipulation {
  id                String                    @id @default(uuid()) @db.Uuid
  dealershipId      String                    @map("dealership_id") @db.Uuid
  lenderApplicationId String                  @map("lender_application_id") @db.Uuid
  type              LenderStipulationTypeNew
  title             String                   @db.VarChar(256)
  notes             String?                  @db.Text
  status            LenderStipulationStatusNew @default(REQUESTED)
  requiredAt        DateTime?                @map("required_at")
  receivedAt        DateTime?                 @map("received_at")
  reviewedAt        DateTime?                 @map("reviewed_at")
  createdByUserId   String?                   @map("created_by_user_id") @db.Uuid
  reviewedByUserId  String?                   @map("reviewed_by_user_id") @db.Uuid
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")

  dealership   Dealership       @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  lenderApplication LenderApplication @relation(fields: [lenderApplicationId], references: [id], onDelete: Cascade)

  @@index([dealershipId])
  @@index([dealershipId, lenderApplicationId])
  @@index([dealershipId, status])
}

model DealDocument {
  id                   String              @id @default(uuid()) @db.Uuid
  dealershipId         String              @map("dealership_id") @db.Uuid
  dealId               String              @map("deal_id") @db.Uuid
  creditApplicationId  String?             @map("credit_application_id") @db.Uuid
  lenderApplicationId  String?             @map("lender_application_id") @db.Uuid
  category             DealDocumentCategory
  title                String              @db.VarChar(255)
  fileObjectId         String              @map("file_object_id") @db.Uuid
  mimeType             String              @map("mime_type") @db.VarChar(128)
  sizeBytes            Int                 @map("size_bytes")
  uploadedByUserId     String              @map("uploaded_by_user_id") @db.Uuid
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")

  dealership   Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  deal         Deal       @relation(fields: [dealId], references: [id], onDelete: Cascade)
  fileObject   FileObject @relation(fields: [fileObjectId], references: [id], onDelete: Cascade)

  @@index([dealershipId])
  @@index([dealershipId, dealId])
  @@index([dealershipId, category])
}

model ComplianceFormInstance {
  id                  String                     @id @default(uuid()) @db.Uuid
  dealershipId        String                     @map("dealership_id") @db.Uuid
  dealId              String                     @map("deal_id") @db.Uuid
  formType            ComplianceFormType         @map("form_type")
  status              ComplianceFormInstanceStatus @default(NOT_STARTED)
  generatedPayloadJson Json?                     @map("generated_payload_json")
  generatedAt         DateTime?                 @map("generated_at")
  completedAt         DateTime?                 @map("completed_at")
  createdByUserId     String?                    @map("created_by_user_id") @db.Uuid
  updatedByUserId     String?                    @map("updated_by_user_id") @db.Uuid
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @updatedAt @map("updated_at")

  dealership Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  deal       Deal       @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealershipId])
  @@index([dealershipId, dealId])
  @@index([dealershipId, formType])
  @@index([dealershipId, status])
}

model AccountingAccount {
  id           String               @id @default(uuid()) @db.Uuid
  dealershipId String               @map("dealership_id") @db.Uuid
  code         String               @db.VarChar(32)
  name         String               @db.VarChar(256)
  type         AccountingAccountType
  isActive     Boolean               @default(true) @map("is_active")
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")

  dealership  Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  entries     AccountingEntry[]

  @@unique([dealershipId, code])
  @@index([dealershipId])
  @@index([dealershipId, isActive])
}

model AccountingTransaction {
  id              String                @id @default(uuid()) @db.Uuid
  dealershipId    String                @map("dealership_id") @db.Uuid
  referenceType   AccountingReferenceType @map("reference_type")
  referenceId     String?               @map("reference_id") @db.Uuid
  memo            String?               @db.VarChar(500)
  postedAt        DateTime?             @map("posted_at") @db.Date
  createdByUserId String?               @map("created_by_user_id") @db.Uuid
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  dealership Dealership         @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  entries    AccountingEntry[]

  @@index([dealershipId])
  @@index([dealershipId, postedAt])
  @@index([dealershipId, referenceType, referenceId])
}

model AccountingEntry {
  id             String                 @id @default(uuid()) @db.Uuid
  dealershipId   String                 @map("dealership_id") @db.Uuid
  transactionId   String                 @map("transaction_id") @db.Uuid
  accountId      String                 @map("account_id") @db.Uuid
  direction      AccountingEntryDirection
  amountCents    BigInt                 @map("amount_cents")
  memo           String?                @db.VarChar(255)
  createdAt      DateTime               @default(now()) @map("created_at")

  dealership  Dealership          @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  transaction AccountingTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  account     AccountingAccount   @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([dealershipId])
  @@index([transactionId])
  @@index([accountId])
}

model DealershipExpense {
  id              String                 @id @default(uuid()) @db.Uuid
  dealershipId    String                 @map("dealership_id") @db.Uuid
  vehicleId       String?                @map("vehicle_id") @db.Uuid
  dealId          String?                @map("deal_id") @db.Uuid
  category        String                 @db.VarChar(128)
  vendor          String?                @db.VarChar(256)
  description     String?                @db.Text
  amountCents     BigInt                 @map("amount_cents")
  incurredOn      DateTime               @map("incurred_on") @db.Date
  status         DealershipExpenseStatus @default(OPEN)
  createdByUserId String?                @map("created_by_user_id") @db.Uuid
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  dealership Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  vehicle    Vehicle?   @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  deal       Deal?      @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([dealershipId])
  @@index([dealershipId, status])
  @@index([dealershipId, incurredOn])
  @@index([dealershipId, vehicleId])
  @@index([dealershipId, dealId])
}

model TaxProfile {
  id              String   @id @default(uuid()) @db.Uuid
  dealershipId    String   @map("dealership_id") @db.Uuid
  name            String   @db.VarChar(128)
  state           String?  @db.VarChar(64)
  county          String?  @db.VarChar(128)
  city            String?  @db.VarChar(128)
  taxRateBps       Int      @map("tax_rate_bps")
  docFeeTaxable    Boolean  @default(true) @map("doc_fee_taxable")
  warrantyTaxable  Boolean  @default(true) @map("warranty_taxable")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  dealership Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)

  @@index([dealershipId])
}

// --- CRM Pipeline + Follow-up Automation (docs/design/crm-pipeline-automation-spec.md) ---
enum OpportunityStatus {
  OPEN
  WON
  LOST
}

enum JobStatus {
  pending
  running
  completed
  failed
  dead_letter
}

enum SequenceInstanceStatus {
  active
  paused
  stopped
  completed
}

enum SequenceStepInstanceStatus {
  pending
  skipped
  completed
  failed
}

model Pipeline {
  id           String   @id @default(uuid()) @db.Uuid
  dealershipId String   @map("dealership_id") @db.Uuid
  name         String
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  dealership Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  stages     Stage[]

  @@index([dealershipId])
}

model Stage {
  id           String   @id @default(uuid()) @db.Uuid
  dealershipId String   @map("dealership_id") @db.Uuid
  pipelineId   String   @map("pipeline_id") @db.Uuid
  order        Int
  name         String
  colorKey     String?  @map("color_key") @db.VarChar(50)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  dealership    Dealership    @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  pipeline      Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  customers     Customer[]
  opportunities Opportunity[]
  activitiesFrom OpportunityActivity[] @relation("ActivityFromStage")
  activitiesTo   OpportunityActivity[] @relation("ActivityToStage")

  @@index([dealershipId])
  @@index([dealershipId, pipelineId])
  @@index([pipelineId, order])
}

model Opportunity {
  id                   String            @id @default(uuid()) @db.Uuid
  dealershipId         String            @map("dealership_id") @db.Uuid
  customerId           String            @map("customer_id") @db.Uuid
  vehicleId            String?           @map("vehicle_id") @db.Uuid
  dealId               String?           @map("deal_id") @db.Uuid
  stageId              String            @map("stage_id") @db.Uuid
  ownerId              String?           @map("owner_id") @db.Uuid
  source               String?
  priority             String?
  estimatedValueCents  BigInt?           @map("estimated_value_cents")
  notes                String?           @db.Text
  nextActionAt         DateTime?         @map("next_action_at")
  nextActionText       String?           @map("next_action_text") @db.VarChar(500)
  status               OpportunityStatus @default(OPEN)
  lossReason           String?           @map("loss_reason") @db.VarChar(255)
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")

  dealership   Dealership   @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  vehicle      Vehicle?     @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  deal         Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  stage        Stage        @relation(fields: [stageId], references: [id], onDelete: Restrict)
  owner        Profile?     @relation("OpportunityOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  activities   OpportunityActivity[]
  sequenceInstances SequenceInstance[]
  inboxConversations InboxConversation[]

  @@index([dealershipId])
  @@index([dealershipId, status])
  @@index([dealershipId, stageId])
  @@index([dealershipId, ownerId])
  @@index([dealershipId, customerId])
  @@index([dealershipId, nextActionAt])
  @@index([dealershipId, createdAt])
  @@index([dealershipId, updatedAt(sort: Desc)], map: "opp_did_updated_desc_idx")
}

model OpportunityActivity {
  id             String    @id @default(uuid()) @db.Uuid
  dealershipId   String    @map("dealership_id") @db.Uuid
  opportunityId  String    @map("opportunity_id") @db.Uuid
  activityType   String    @map("activity_type")
  fromStageId    String?   @map("from_stage_id") @db.Uuid
  toStageId      String?   @map("to_stage_id") @db.Uuid
  metadata       Json?
  actorId        String?   @map("actor_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")

  dealership  Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  fromStage   Stage?     @relation("ActivityFromStage", fields: [fromStageId], references: [id], onDelete: SetNull)
  toStage     Stage?     @relation("ActivityToStage", fields: [toStageId], references: [id], onDelete: SetNull)
  actor       Profile?   @relation("OpportunityActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([dealershipId])
  @@index([dealershipId, opportunityId, createdAt])
}

model AutomationRule {
  id                String    @id @default(uuid()) @db.Uuid
  dealershipId       String    @map("dealership_id") @db.Uuid
  name               String
  triggerEvent       String    @map("trigger_event")
  triggerConditions  Json?     @map("trigger_conditions")
  actions            Json
  schedule           String    @db.VarChar(50)
  isActive           Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  dealership   Dealership    @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  automationRuns AutomationRun[]

  @@index([dealershipId])
  @@index([dealershipId, isActive])
  @@index([dealershipId, deletedAt])
}

model AutomationRun {
  id           String   @id @default(uuid()) @db.Uuid
  dealershipId String   @map("dealership_id") @db.Uuid
  entityType   String   @map("entity_type")
  entityId     String   @map("entity_id") @db.Uuid
  eventKey     String   @map("event_key")
  ruleId       String   @map("rule_id") @db.Uuid
  runAt        DateTime @map("run_at")
  status       String
  createdAt    DateTime @default(now()) @map("created_at")

  dealership Dealership    @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  rule       AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([dealershipId, entityType, entityId, eventKey, ruleId])
  @@index([dealershipId])
}

model Job {
  id               String    @id @default(uuid()) @db.Uuid
  dealershipId     String    @map("dealership_id") @db.Uuid
  queueType       String    @map("queue_type")
  payload          Json
  idempotencyKey   String?   @map("idempotency_key") @db.VarChar(255)
  scheduledAt      DateTime  @map("scheduled_at")
  runAt            DateTime  @map("run_at")
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  status          JobStatus @default(pending)
  retryCount      Int       @default(0) @map("retry_count")
  maxRetries      Int       @default(3) @map("max_retries")
  errorMessage    String?   @map("error_message") @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  dealership Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)

  @@index([dealershipId])
  @@index([dealershipId, status, runAt])
  @@index([dealershipId, queueType])
}

model DealerJobRun {
  id            String    @id @default(uuid()) @db.Uuid
  dealershipId  String    @map("dealership_id") @db.Uuid
  startedAt    DateTime  @map("started_at")
  finishedAt   DateTime  @map("finished_at")
  processed    Int       @default(0)
  failed       Int       @default(0)
  deadLetter   Int       @default(0) @map("dead_letter")
  skippedReason String?  @map("skipped_reason") @db.VarChar(500)
  durationMs   Int       @map("duration_ms")

  dealership Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)

  @@index([dealershipId, startedAt])
  @@map("dealer_job_runs")
}

model DealerJobRunsDaily {
  id            String    @id @default(uuid()) @db.Uuid
  day           DateTime  @db.Date
  dealershipId  String    @map("dealership_id") @db.Uuid
  totalRuns     Int       @map("total_runs")
  skippedRuns   Int       @map("skipped_runs")
  processedRuns Int       @map("processed_runs")
  failedRuns    Int       @map("failed_runs")
  avgDurationMs Int       @map("avg_duration_ms")
  createdAt     DateTime  @default(now()) @map("created_at")

  dealership Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)

  @@unique([day, dealershipId])
  @@index([day])
  @@index([dealershipId])
  @@index([day, dealershipId])
  @@map("dealer_job_runs_daily")
}

enum IntelligenceSignalDomain {
  INVENTORY
  CRM
  DEALS
  OPERATIONS
  ACQUISITION
}

enum IntelligenceSignalSeverity {
  INFO
  SUCCESS
  WARNING
  DANGER
}

model IntelligenceSignal {
  id           String                     @id @default(uuid()) @db.Uuid
  dealershipId String                     @map("dealership_id") @db.Uuid
  domain       IntelligenceSignalDomain
  code         String                     @db.VarChar(128)
  severity     IntelligenceSignalSeverity @default(INFO)
  title        String                     @db.VarChar(200)
  description  String?                    @db.Text
  entityType   String?                    @map("entity_type") @db.VarChar(64)
  entityId     String?                    @map("entity_id") @db.Uuid
  actionLabel  String?                    @map("action_label") @db.VarChar(120)
  actionHref   String?                    @map("action_href") @db.VarChar(512)
  metadata     Json?
  happenedAt   DateTime                   @default(now()) @map("happened_at")
  resolvedAt   DateTime?                  @map("resolved_at")
  createdAt    DateTime                   @default(now()) @map("created_at")
  updatedAt    DateTime                   @updatedAt @map("updated_at")
  deletedAt    DateTime?                  @map("deleted_at")

  dealership Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)

  @@index([dealershipId])
  @@index([dealershipId, domain, severity])
  @@index([dealershipId, resolvedAt, happenedAt])
  @@index([dealershipId, code, createdAt])
  @@index([dealershipId, domain, code, resolvedAt, deletedAt, entityType, entityId], map: "isig_active_lookup_idx")
  @@index([dealershipId, deletedAt])
  @@map("intelligence_signals")
}

model SequenceTemplate {
  id           String    @id @default(uuid()) @db.Uuid
  dealershipId String    @map("dealership_id") @db.Uuid
  name         String
  description  String?   @db.Text
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  dealership Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  steps      SequenceStep[]
  instances  SequenceInstance[]

  @@index([dealershipId])
  @@index([dealershipId, deletedAt])
}

model SequenceStep {
  id           String   @id @default(uuid()) @db.Uuid
  dealershipId String   @map("dealership_id") @db.Uuid
  templateId   String   @map("template_id") @db.Uuid
  order        Int
  stepType     String   @map("step_type")
  config       Json?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  dealership Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  template   SequenceTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  stepInstances SequenceStepInstance[]

  @@index([dealershipId])
  @@index([templateId, order])
}

model SequenceInstance {
  id             String                 @id @default(uuid()) @db.Uuid
  dealershipId   String                 @map("dealership_id") @db.Uuid
  templateId     String                 @map("template_id") @db.Uuid
  opportunityId  String?                @map("opportunity_id") @db.Uuid
  customerId     String?                @map("customer_id") @db.Uuid
  status         SequenceInstanceStatus @default(active)
  startedAt      DateTime               @map("started_at")
  stoppedAt      DateTime?              @map("stopped_at")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")

  dealership  Dealership        @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  template   SequenceTemplate   @relation(fields: [templateId], references: [id], onDelete: Restrict)
  opportunity Opportunity?     @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  customer   Customer?          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  stepInstances SequenceStepInstance[]

  @@index([dealershipId])
  @@index([dealershipId, opportunityId])
  @@index([dealershipId, customerId])
  @@index([dealershipId, status])
}

model SequenceStepInstance {
  id           String                    @id @default(uuid()) @db.Uuid
  dealershipId String                    @map("dealership_id") @db.Uuid
  instanceId   String                    @map("instance_id") @db.Uuid
  stepId       String                    @map("step_id") @db.Uuid
  scheduledAt  DateTime                  @map("scheduled_at")
  executedAt   DateTime?                 @map("executed_at")
  status       SequenceStepInstanceStatus @default(pending)
  error        String?                   @db.Text
  createdAt    DateTime                  @default(now()) @map("created_at")
  updatedAt    DateTime                  @updatedAt @map("updated_at")

  dealership Dealership        @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  instance   SequenceInstance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  step       SequenceStep      @relation(fields: [stepId], references: [id], onDelete: Restrict)

  @@index([dealershipId])
  @@index([instanceId, scheduledAt])
  @@index([dealershipId, instanceId])
}
