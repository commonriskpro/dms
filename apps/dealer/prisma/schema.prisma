// --- Deals module (docs/design/deals-spec.md) ---
enum DealStatus {
  DRAFT
  STRUCTURED
  APPROVED
  CONTRACTED
  CANCELED
}

enum DeliveryStatus {
  READY_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum DealFundingStatus {
  NONE
  PENDING
  APPROVED
  FUNDED
  FAILED
}

model Deal {
  id                 String     @id @default(uuid()) @db.Uuid
  dealershipId       String     @map("dealership_id") @db.Uuid
  customerId         String     @map("customer_id") @db.Uuid
  vehicleId          String     @map("vehicle_id") @db.Uuid
  salePriceCents     BigInt     @map("sale_price_cents")
  purchasePriceCents BigInt     @map("purchase_price_cents")
  taxRateBps         Int        @map("tax_rate_bps")
  taxCents           BigInt     @map("tax_cents")
  docFeeCents        BigInt     @map("doc_fee_cents")
  downPaymentCents   BigInt     @map("down_payment_cents")
  totalFeesCents     BigInt     @map("total_fees_cents")
  totalDueCents      BigInt     @map("total_due_cents")
  frontGrossCents    BigInt     @map("front_gross_cents")
  status             DealStatus @default(DRAFT)
  deliveryStatus     DeliveryStatus? @map("delivery_status")
  deliveredAt        DateTime?  @map("delivered_at")
  notes              String?    @db.Text
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")
  deletedAt          DateTime?  @map("deleted_at")
  deletedBy          String?    @map("deleted_by") @db.Uuid

  dealership         Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  customer           Customer   @relation(fields: [customerId], references: [id], onDelete: Restrict)
  vehicle            Vehicle    @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  deletedByProfile   Profile?   @relation("DealDeletedBy", fields: [deletedBy], references: [id])
  opportunities      Opportunity[]
  fees               DealFee[]
  trades             DealTrade[]
  history            DealHistory[]
  dealFinance        DealFinance?
  financeApplications FinanceApplication[]
  financeSubmissions   FinanceSubmission[]
  creditApplications   CreditApplication[]
  lenderApplications    LenderApplication[]
  dealDocuments        DealDocument[]
  complianceFormInstances ComplianceFormInstance[]
  dealershipExpenses   DealershipExpense[]
  dealFundings       DealFunding[]
  dealTitle          DealTitle?
  dealDmvChecklistItems DealDmvChecklistItem[]

  @@index([dealershipId])
  @@index([dealershipId, status])
  @@index([dealershipId, deliveryStatus])
  @@index([dealershipId, createdAt])
  @@index([dealershipId, customerId])
  @@index([dealershipId, vehicleId])
  @@index([dealershipId, deletedAt])
}

enum TitleStatus {
  NOT_STARTED
  TITLE_PENDING
  TITLE_SENT
  TITLE_RECEIVED
  TITLE_COMPLETED
  ISSUE_HOLD
}

model DealTitle {
  id                   String      @id @default(uuid()) @db.Uuid
  dealershipId         String      @map("dealership_id") @db.Uuid
  dealId               String      @unique @map("deal_id") @db.Uuid
  titleStatus          TitleStatus @default(NOT_STARTED) @map("title_status")
  titleNumber          String?     @map("title_number") @db.VarChar(128)
  lienholderName       String?     @map("lienholder_name") @db.VarChar(256)
  lienReleasedAt       DateTime?   @map("lien_released_at")
  sentToDmvAt          DateTime?   @map("sent_to_dmv_at")
  receivedFromDmvAt    DateTime?   @map("received_from_dmv_at")
  notes                String?     @db.Text
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")

  dealership   Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  deal         Deal       @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealershipId])
  @@index([dealershipId, titleStatus])
  @@index([dealershipId, createdAt])
}

model DealDmvChecklistItem {
  id           String    @id @default(uuid()) @db.Uuid
  dealershipId String    @map("dealership_id") @db.Uuid
  dealId       String    @map("deal_id") @db.Uuid
  label        String    @db.VarChar(256)
  completed    Boolean   @default(false)
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  dealership   Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  deal         Deal       @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealershipId])
  @@index([dealershipId, dealId])
}

model DealFee {
  id           String   @id @default(uuid()) @db.Uuid
  dealershipId String   @map("dealership_id") @db.Uuid
  dealId       String   @map("deal_id") @db.Uuid
  label        String
  amountCents  BigInt   @map("amount_cents")
  taxable      Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")

  dealership   Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  deal         Deal       @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealershipId])
  @@index([dealershipId, dealId])
}

model DealTrade {
  id                  String   @id @default(uuid()) @db.Uuid
  dealershipId        String   @map("dealership_id") @db.Uuid
  dealId              String   @map("deal_id") @db.Uuid
  vehicleDescription  String   @map("vehicle_description")
  allowanceCents      BigInt   @map("allowance_cents")
  payoffCents         BigInt   @map("payoff_cents")
  createdAt           DateTime @default(now()) @map("created_at")

  dealership   Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  deal         Deal       @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealershipId])
  @@index([dealershipId, dealId])
}

model DealHistory {
  id           String     @id @default(uuid()) @db.Uuid
  dealershipId String     @map("dealership_id") @db.Uuid
  dealId       String     @map("deal_id") @db.Uuid
  fromStatus   DealStatus? @map("from_status")
  toStatus     DealStatus  @map("to_status")
  changedBy    String?     @map("changed_by") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")

  dealership   Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  deal        Deal        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  changedByProfile Profile? @relation("DealHistoryChangedBy", fields: [changedBy], references: [id], onDelete: SetNull)

  @@index([dealershipId])
  @@index([dealershipId, dealId, createdAt])
}

model DealFunding {
  id                   String           @id @default(uuid()) @db.Uuid
  dealershipId         String           @map("dealership_id") @db.Uuid
  dealId               String           @map("deal_id") @db.Uuid
  lenderApplicationId   String?          @map("lender_application_id") @db.Uuid
  fundingStatus        DealFundingStatus @default(PENDING) @map("funding_status")
  fundingAmountCents   BigInt           @map("funding_amount_cents")
  fundingDate          DateTime?        @map("funding_date")
  notes                String?         @db.Text
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  dealership         Dealership       @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  deal               Deal             @relation(fields: [dealId], references: [id], onDelete: Cascade)
  lenderApplication  LenderApplication? @relation(fields: [lenderApplicationId], references: [id], onDelete: SetNull)

  @@index([dealershipId])
  @@index([dealershipId, dealId])
  @@index([dealershipId, fundingStatus])
  @@index([dealershipId, createdAt])
}

// --- Finance Shell (docs/design/finance-shell-spec.md) ---
enum FinancingMode {
