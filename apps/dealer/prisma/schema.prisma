  dealership Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)

  @@index([dealershipId])
  @@index([dealershipId, enabled])
}

enum VehicleListingPlatform {
  WEBSITE
  AUTOTRADER
  CARS
  CARFAX
  FACEBOOK
}

enum VehicleListingStatus {
  DRAFT
  PUBLISHED
  FAILED
  UNPUBLISHED
}

model VehicleListing {
