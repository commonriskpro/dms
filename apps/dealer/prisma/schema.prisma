  recommendedRetailCents   Int      @map("recommended_retail_cents")
  recommendedWholesaleCents Int     @map("recommended_wholesale_cents")
  priceToMarketPercent     Float?   @map("price_to_market_percent")
  marketDaysSupply        Int?     @map("market_days_supply")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  dealership Dealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)
  vehicle    Vehicle    @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([dealershipId])
  @@index([dealershipId, vehicleId])
  @@index([vehicleId])
}

enum PricingRuleType {
  AGE_BASED
  MARKET_BASED
  CLEARANCE
}

model PricingRule {
  id                String         @id @default(uuid()) @db.Uuid
  dealershipId      String         @map("dealership_id") @db.Uuid
  name              String         @db.VarChar(256)
  ruleType          PricingRuleType @map("rule_type")
  daysInStock       Int?           @map("days_in_stock")
  adjustmentPercent Float?         @map("adjustment_percent")
  adjustmentCents   Int?           @map("adjustment_cents")
  enabled           Boolean        @default(true)
  createdAt         DateTime       @default(now()) @map("created_at")
