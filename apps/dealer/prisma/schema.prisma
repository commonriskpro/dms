  vehicle    Vehicle    @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([dealershipId, vehicleId, platform])
  @@index([dealershipId])
  @@index([dealershipId, vehicleId])
  @@index([dealershipId, platform, status])
}

enum ReconItemStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model ReconItem {
