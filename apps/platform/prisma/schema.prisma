// Platform DB only. No tenant data. Separate from dealer Prisma.

generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/platform-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlatformRole {
  PLATFORM_OWNER
  PLATFORM_COMPLIANCE
  PLATFORM_SUPPORT
}

model PlatformUser {
  id         String       @id @default(uuid()) @db.Uuid
  role       PlatformRole
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")
  disabledAt DateTime?    @map("disabled_at")

  @@map("platform_users")
}

enum PlatformAccountStatus {
  ACTIVE
  SUSPENDED
}

model PlatformAccount {
  id        String                @id @default(uuid()) @db.Uuid
  name      String                @map("name")
  email     String                @map("email")
  status    PlatformAccountStatus @default(ACTIVE) @map("status")
  createdAt DateTime              @default(now()) @map("created_at")
  updatedAt DateTime              @updatedAt @map("updated_at")

  dealerships PlatformDealership[]

  @@index([status])
  @@map("platform_accounts")
}

enum ApplicationStatus {
  APPLIED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum PlatformDealerApplicationSource {
  invite
  public_apply
}

enum PlatformDealerApplicationStatus {
  draft
  invited
  submitted
  under_review
  approved
  rejected
  activation_sent
  activated
}

model Application {
  id               String            @id @default(uuid()) @db.Uuid
  status           ApplicationStatus  @default(APPLIED)
  legalName        String            @map("legal_name")
  displayName      String            @map("display_name")
  contactEmail     String            @map("contact_email")
  contactPhone     String?           @map("contact_phone")
  notes            String?           @db.Text
  reviewNotes      String?           @map("review_notes") @db.Text
  rejectionReason  String?           @map("rejection_reason") @db.Text
  dealershipId     String?           @unique @map("dealership_id") @db.Uuid
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  dealership       PlatformDealership? @relation(fields: [dealershipId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
  @@map("applications")
}

model PlatformDealerApplication {
  id                  String                         @id @default(uuid()) @db.Uuid
  dealerApplicationId String                         @unique @map("dealer_application_id") @db.Uuid
  source              PlatformDealerApplicationSource
  status              PlatformDealerApplicationStatus @default(draft)
  ownerEmail          String                         @map("owner_email")
  dealerInviteId      String?                        @map("dealer_invite_id") @db.Uuid
  invitedByUserId     String?                        @map("invited_by_user_id") @db.Uuid
  dealerDealershipId  String?                        @map("dealer_dealership_id") @db.Uuid
  platformApplicationId String?                      @map("platform_application_id") @db.Uuid
  platformDealershipId String?                       @map("platform_dealership_id") @db.Uuid
  submittedAt         DateTime?                      @map("submitted_at")
  approvedAt          DateTime?                      @map("approved_at")
  rejectedAt          DateTime?                      @map("rejected_at")
  activationSentAt    DateTime?                      @map("activation_sent_at")
  activatedAt         DateTime?                      @map("activated_at")
  reviewerUserId      String?                        @map("reviewer_user_id") @db.Uuid
  reviewNotes         String?                        @map("review_notes") @db.Text
  rejectionReason     String?                        @map("rejection_reason") @db.Text
  createdAt           DateTime                       @default(now()) @map("created_at")
  updatedAt           DateTime                       @updatedAt @map("updated_at")

  dealership PlatformDealership?              @relation(fields: [platformDealershipId], references: [id], onDelete: SetNull)
  profile    PlatformDealerApplicationProfile?

  @@index([status])
  @@index([source, status])
  @@index([ownerEmail])
  @@index([platformDealershipId])
  @@index([dealerDealershipId])
  @@index([submittedAt])
  @@index([createdAt])
  @@map("platform_dealer_applications")
}

model PlatformDealerApplicationProfile {
  id                     String   @id @default(uuid()) @db.Uuid
  applicationId          String   @unique @map("application_id") @db.Uuid
  businessInfo           Json?    @map("business_info")
  ownerInfo              Json?    @map("owner_info")
  primaryContact         Json?    @map("primary_contact")
  additionalLocations    Json?    @map("additional_locations")
  pricingPackageInterest Json?    @map("pricing_package_interest")
  acknowledgments        Json?    @map("acknowledgments")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  application PlatformDealerApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("platform_dealer_application_profiles")
}

enum PlatformDealershipStatus {
  APPROVED
  PROVISIONING
  PROVISIONED
  ACTIVE
  SUSPENDED
  CLOSED
}

model PlatformDealership {
  id                  String                   @id @default(uuid()) @db.Uuid
  platformAccountId   String?                  @map("platform_account_id") @db.Uuid
  legalName           String                   @map("legal_name")
  displayName         String                   @map("display_name")
  slug                String?                  @unique @map("slug") @db.VarChar(128)
  planKey             String                   @map("plan_key")
  limits              Json?                    @default("{}")
  status              PlatformDealershipStatus  @default(APPROVED)
  createdAt           DateTime                 @default(now()) @map("created_at")
  updatedAt           DateTime                 @updatedAt @map("updated_at")

  platformAccount PlatformAccount?  @relation(fields: [platformAccountId], references: [id], onDelete: SetNull)
  mapping         DealershipMapping?
  applications     Application[]
  dealerApplications PlatformDealerApplication[]
  subscription    PlatformSubscription?

  @@index([status])
  @@index([platformAccountId])
  @@map("platform_dealerships")
}

enum SubscriptionPlan {
  STARTER
  PRO
  ENTERPRISE
}

enum BillingStatus {
  ACTIVE
  TRIAL
  PAST_DUE
  CANCELLED
}

model PlatformSubscription {
  id                     String          @id @default(uuid()) @db.Uuid
  dealershipId           String          @unique @map("dealership_id") @db.Uuid
  plan                   SubscriptionPlan @map("plan")
  billingStatus          BillingStatus    @default(ACTIVE) @map("billing_status")
  billingProvider        String?         @map("billing_provider") @db.VarChar(64)
  billingCustomerId      String?         @map("billing_customer_id") @db.VarChar(255)
  billingSubscriptionId  String?         @map("billing_subscription_id") @db.VarChar(255)
  currentPeriodEnd       DateTime?       @map("current_period_end")
  createdAt              DateTime        @default(now()) @map("created_at")
  updatedAt              DateTime        @updatedAt @map("updated_at")

  dealership PlatformDealership @relation(fields: [dealershipId], references: [id], onDelete: Cascade)

  @@index([billingStatus])
  @@map("platform_subscriptions")
}

model DealershipMapping {
  id                   String   @id @default(uuid()) @db.Uuid
  platformDealershipId String   @unique @map("platform_dealership_id") @db.Uuid
  dealerDealershipId   String   @unique @map("dealer_dealership_id") @db.Uuid
  provisionedAt        DateTime @map("provisioned_at")
  createdAt            DateTime @default(now()) @map("created_at")

  platformDealership PlatformDealership @relation(fields: [platformDealershipId], references: [id], onDelete: Cascade)

  @@map("dealership_mapping")
}

model PlatformAuditLog {
  id                   String   @id @default(uuid()) @db.Uuid
  actorPlatformUserId  String   @map("actor_platform_user_id") @db.Uuid
  action               String
  targetType           String   @map("target_type")
  targetId             String?  @map("target_id") @db.Uuid
  beforeState          Json?    @map("before_state")
  afterState           Json?    @map("after_state")
  reason               String?  @db.Text
  requestId            String?  @map("request_id") @db.VarChar(255)
  idempotencyKey       String?  @map("idempotency_key") @db.VarChar(255)
  createdAt            DateTime @default(now()) @map("created_at")

  @@index([actorPlatformUserId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("platform_audit_logs")
}

enum PlatformEmailLogType {
  OWNER_INVITE
}

model PlatformEmailLog {
  id                    String              @id @default(uuid()) @db.Uuid
  platformDealershipId  String              @map("platform_dealership_id") @db.Uuid
  type                  PlatformEmailLogType
  recipientHash         String              @map("recipient_hash") @db.VarChar(64)
  sentAt                DateTime            @map("sent_at")
  requestId             String?             @map("request_id") @db.VarChar(255)

  @@index([platformDealershipId, type, recipientHash, sentAt])
  @@map("platform_email_logs")
}

model PlatformInviteLog {
  id            String   @id @default(uuid()) @db.Uuid
  recipientHash String   @map("recipient_hash") @db.VarChar(64)
  sentAt        DateTime @map("sent_at")

  @@index([recipientHash, sentAt])
  @@map("platform_invite_logs")
}

model InternalApiJti {
  jti       String   @id @db.VarChar(255)
  expiresAt DateTime @map("expires_at")

  @@index([expiresAt])
  @@map("internal_api_jti")
}

// --- Platform monitoring (dealer-health alerting) ---

enum PlatformMonitoringEventType {
  DEALER_HEALTH_FAIL
  DEALER_HEALTH_RECOVER
}

enum PlatformAlertStatus {
  OK
  FAIL
}

model PlatformMonitoringEvent {
  id                   String                      @id @default(uuid()) @db.Uuid
  type                 PlatformMonitoringEventType
  platformDealershipId String?                     @map("platform_dealership_id") @db.Uuid
  dealerBaseUrl       String                      @map("dealer_base_url") @db.VarChar(2048)
  upstreamStatus      Int                          @map("upstream_status")
  requestId           String                      @map("request_id") @db.VarChar(255)
  createdAt           DateTime                    @default(now()) @map("created_at")

  @@index([type, createdAt])
  @@index([createdAt])
  @@map("platform_monitoring_events")
}

model PlatformAlertState {
  id               String             @id @default(uuid()) @db.Uuid
  key              String             @unique @db.VarChar(128)
  lastStatus       PlatformAlertStatus @map("last_status")
  lastChangeAt     DateTime          @map("last_change_at")
  consecutiveFails Int               @default(0) @map("consecutive_fails")
  lastAlertSentAt  DateTime?         @map("last_alert_sent_at")

  @@map("platform_alert_state")
}
