# Platform app — copy to .env.platform-admin and fill in. Used by: db:migrate:platform, db:seed:platform.
# Get DATABASE_URL from Platform Supabase: Settings → Database → Connection string.

DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# Optional: direct connection (port 5432) for db:migrate:platform, db:migrate:status:platform, db:reset:platform — avoids pooler hang
# DIRECT_DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# Platform app URL — local: http://localhost:3001 | Vercel: https://your-platform.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Auth (for platform login and scripts/delete-all-supabase-users.ts). From Platform Supabase: Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://[platform-project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# For db:seed:platform (create first platform owner). Get user UUID from Supabase Auth → Users.
PLATFORM_OWNER_USER_ID=
# Optional: ROLE=PLATFORM_OWNER | PLATFORM_COMPLIANCE | PLATFORM_SUPPORT

# DEV-ONLY: Diagnose platform login loop. Enables auth debug logs (no tokens/PII). Server + client.
# PLATFORM_AUTH_DEBUG=true
# NEXT_PUBLIC_PLATFORM_AUTH_DEBUG=true
